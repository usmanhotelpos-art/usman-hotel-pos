{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "up": "node server/index.js",
      "envPathFile": "server/.env",
      "startCommand": "node server/index.js"
    },
    "frontend": {
      "build": {
        "builder": "nixpacks",
        "buildCommand": "npm run build"
      },
      "start": "npm --workspace client run preview",
      "envPathFile": "client/.env.production"
    }
  }
}
